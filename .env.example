# Backend Environment Variables Template

# Server Configuration
PORT=3000

# Firebase Admin Credentials (get these from Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Important: Ensure the private key is wrapped in quotes if it contains newlines, or replace newlines with \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# API Keys (if needed for other services)
# GOOGLE_MAPS_API_KEY=your-key-here
